# WindowsPE frontend — ortam değişkenleri
# Bu dosya git'e girer; gerçek değerleri içeren .env.local ASLA git'e girmez.
#
# Kullanım:
#   cp frontend/.env.example frontend/.env.local
#   # Değerleri düzenle, sonra `npm run dev` / `npm run build`


# ─── Backend API ──────────────────────────────────────────────────────────────

# Rust/Axum backend'in public API base URL'si.
# NE       : Tarayıcının API isteklerini göndereceği adres
# NEREDEN  : Kendi backend deploy URL'in (Fly.io, Railway, VPS, vb.)
#            Yerel geliştirme: cargo run'ın dinlediği adres
# FORMAT   : Şema + host + port + yol prefix
#            Örn: https://api.siteniz.com/api/v1
# ZORUNLU  : Hayır — varsayılan localhost geliştime için uygundur;
#            production'da mutlaka ayarla
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# ÖNEMLİ (production):
#   NEXT_PUBLIC_API_BASE_URL=https://api.siteniz.com/api/v1
#
# Bu değişken tarayıcıya inline edilir (NEXT_PUBLIC_ öneki).
# Gerçek URL'yi buraya yaz; .env.local dosyasında sakla.

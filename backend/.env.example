# WindowsPE backend — ortam değişkenleri
# Tüm değişkenler `WINDOWSPE_` önekiyle başlar ve config::Config alanlarıyla
# birebir eşleşir. Kodda varsayılan değerler tanımlıdır; değişkeni ayarlamasan
# bile backend çalışır — değerler sadece production'da özelleştirilmeli.
#
# Kullanım:
#   cp backend/.env.example backend/.env   # gerçek .env ASLA git'e girmemeli
#   # İstediğin değerleri düzenle, sonra `cargo run` / `cargo build`


# ─── Sunucu ───────────────────────────────────────────────────────────────────

# Dinlenecek IP:port.
# NE       : TCP bağlama adresi
# NEREDEN  : İstediğin herhangi bir IP:port
# FORMAT   : <ip>:<port>  örn. 0.0.0.0:8080 (tüm arayüzler) veya 127.0.0.1:8080
# ZORUNLU  : Hayır — varsayılan: 127.0.0.1:8080
WINDOWSPE_BIND_ADDR=127.0.0.1:8080


# ─── Veritabanı ───────────────────────────────────────────────────────────────

# SQLite bağlantı URL'si.
# NE       : SQLite dosyasının yolu (mode=rwc → yoksa oluşturur)
# NEREDEN  : Yerel dosya sistemi; backend/ dizinine göre göreli veya mutlak yol
# FORMAT   : sqlite://<yol>?mode=rwc
#            Test için: sqlite::memory:
# ZORUNLU  : Hayır — varsayılan: sqlite://./windowspe.db?mode=rwc
WINDOWSPE_DATABASE_URL=sqlite://./windowspe.db?mode=rwc


# ─── İçerik ───────────────────────────────────────────────────────────────────

# Git-versiyonlanmış içerik ağacının yolu.
# NE       : backend'in başlangıçta okuyacağı JSON methodology dosyalarının
#            bulunduğu dizin
# NEREDEN  : Repodaki content/ dizini (backend/'e göre göreli veya mutlak)
# FORMAT   : Göreli yol (../content) veya mutlak (/srv/windowspe/content)
# ZORUNLU  : Hayır — varsayılan: ../content
WINDOWSPE_CONTENT_DIR=../content


# ─── Loglama ──────────────────────────────────────────────────────────────────

# tracing-subscriber EnvFilter direktifi.
# NE       : Log seviyesi filtresi
# NEREDEN  : Rust tracing-subscriber EnvFilter sözdizimi
# FORMAT   : info | debug | warn | error | debug,sqlx=warn
# ZORUNLU  : Hayır — varsayılan: info
WINDOWSPE_LOG_LEVEL=info


# ─── Önbellekleme ─────────────────────────────────────────────────────────────

# Methodology ağacı için bellek içi önbellek TTL'si (saniye).
# NE       : Önbellekte tutulan veri kaç saniyede bir tazelenir
# NEREDEN  : İstediğin bir tam sayı (saniye cinsinden)
# FORMAT   : Tam sayı, örn. 300 (5 dakika) veya 60 (1 dakika)
# ZORUNLU  : Hayır — varsayılan: 300
WINDOWSPE_CACHE_TTL_SECS=300


# ─── CORS ─────────────────────────────────────────────────────────────────────

# İzin verilen frontend origin'lerinin virgülle ayrılmış listesi.
# NE       : Tarayıcıların CORS isteği gönderebileceği kaynaklar
# NEREDEN  : Frontend'in deploy edildiği URL(ler)
# FORMAT   : Tam origin (şema + alan adı + port), virgülle ayrılmış
#            Örn: https://siteniz.com,https://www.siteniz.com
#            Boş bırakılırsa tüm cross-origin istekler reddedilir (fail-closed)
# ZORUNLU  : Production'da EVET — geliştirmede localhost varsayılan olarak çalışır
WINDOWSPE_CORS_ORIGINS=http://localhost:3000

# ÖNEMLİ (production):
#   WINDOWSPE_CORS_ORIGINS=https://siteniz.com,https://www.siteniz.com
#
# Boş değer = tüm cross-origin istekler reddedilir (router.rs'deki fail-closed
# mantığı — AllowOrigin::any() YOK, bilerek böyle tasarlandı).
